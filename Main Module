    print(f'Example assignment output for MIDN 230001 including their happiness score out of {var1}: {example1}')
    
    

    
    df = pd.DataFrame(dataframe)
    df = df.T
    
    import altair as alt

    
    base = (
        alt.Chart(df).mark_point(size=5).encode(
