                    i = c
                    happy += chappy[mid,b,c]
            for p in PTEs:
                if pyo.value(model.p[mid,b,p]) == 1:
                    i = p
                    happy += phappy[mid,b,p]
                    
                    
            list.append(f'{b}: {i}')
        list.append(happy)
        assignments[mid] = list
        
    #Three classes and three happiness weights per class
    divisor = 9*sum(happiness_weight['first'] for n in range(1,1101))
    obj = 100*(sum(assignments[i][3] for i in MIDN))/divisor
    print(f'The model objective is: {obj:.2f}%')
    
    example1 = assignments['230001']
