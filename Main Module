    #Var for assignment of Cruises
    model.c = pyo.Var(MIDN, blocks, cruises, domain=pyo.Boolean)
        
    equalizer = happiness_weight['first'] - happiness_weight['second']
    
    def obj(model):
        return (
        (sum(model.l[m,b]*lhappy[m,b]*1/OOM[m] for m in MIDN for b in blocks) + 
        sum(model.c[m,b,c]*chappy[m,b,c]*1/OOM[m] for m in MIDN for b in blocks for c in cruises) + 
        sum(model.p[m,b,p]*phappy[m,b,p]*1/OOM[m] for m in MIDN for b in blocks for p in PTEs))
    )
    model.obj = pyo.Objective(rule = obj, sense = pyo.maximize)
    
    def one(model, m):
        return sum(model.l[m,b] for b in blocks) >= 1 - MIDS[m]['Do you want to voluntarily give up leave?']
    model.one = pyo.Constraint(MIDN, rule = one)
    
    def two(model, m):
        return sum(model.c[m,b,c] for b in blocks for c in cruises) == 1
    model.two = pyo.Constraint(MIDN, rule = two)
    
    def three(model, m):
        return sum(model.p[m,b,p] for b in blocks for p in PTEs) >= 1
    model.three = pyo.Constraint(MIDN, rule = three)
    
    def four(model, m, b):
        return model.l[m,b] + sum(model.p[m,b,p] for p in PTEs) + sum(model.c[m,b,c] for c in cruises) == 1
    model.four = pyo.Constraint(MIDN, blocks, rule = four)
    
    def five(model, m, p):
        return sum(model.p[m,b,p] for b in blocks) <= 1
    model.five = pyo.Constraint(MIDN, PTEs, rule = five)
    
    def six(model, b, p):
        return sum(model.p[m,b,p] for m in MIDN) >= MINS[b,p]
    model.six = pyo.Constraint(blocks, PTEs, rule = six)
    
