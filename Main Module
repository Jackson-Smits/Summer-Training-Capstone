                if pyo.value(model.c[mid,b,c]) == 1:
                    key = (c,b)
                    totals[key] += 1
    for p in PTEs:
        for b in blocks:
            key = (p,b)
            totals[key] = 0
    for mid in MIDN:
        for p in PTEs:
            for b in blocks:
                if pyo.value(model.p[mid,b,p]) == 1:
                    key = (p,b)
                    totals[key] += 1
    totals_df = pd.DataFrame.from_dict(totals, orient = 'index')
    
